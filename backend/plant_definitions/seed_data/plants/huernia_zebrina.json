  "translations": {
    "en": {
      "common_name": "Lifesaver Plant",
      "description": "Huernia zebrina, also known as Lifesaver Plant, is a slow-growing succulent with fleshy stems and ring-shaped, striped flowers. It thrives in bright, indirect light and requires minimal watering."
    },
    "pl": {
      "common_name": "Roślina koło ratunkowe",
      "description": "Huernia zebrina, znana jako roślina koło ratunkowe, to wolno rosnący sukulent o mięsistych pędach i pasiastych kwiatach w kształcie pierścienia. Lubi jasne, rozproszone światło i oszczędne podlewanie."
    },
    "de": {
      "common_name": "Rettungsring-Pflanze",
      "description": "Huernia zebrina, auch Rettungsring-Pflanze genannt, ist eine langsam wachsende Sukkulente mit fleischigen Trieben und gestreiften, ringförmigen Blüten. Sie gedeiht bei hellem, indirektem Licht und braucht wenig Wasser."
    },
    "fr": {
      "common_name": "Plante bouée de sauvetage",
      "description": "Huernia zebrina, appelée plante bouée de sauvetage, est une succulente à croissance lente avec des tiges charnues et des fleurs rayées en forme d’anneau. Elle aime la lumière vive indirecte et les arrosages légers."
    },
    "it": {
      "common_name": "Pianta salvagente",
      "description": "Huernia zebrina, nota come pianta salvagente, è una succulenta a crescita lenta con fusti carnosi e fiori striati a forma di anello. Cresce bene in luce intensa indiretta e richiede poca acqua."
    },
    "es": {
      "common_name": "Planta salvavidas",
      "description": "Huernia zebrina, conocida como planta salvavidas, es una suculenta de crecimiento lento con tallos carnosos y flores rayadas en forma de anillo. Prefiere luz brillante indirecta y riego escaso."
    },
    "pt": {
      "common_name": "Planta salva-vidas",
      "description": "Huernia zebrina, conhecida como planta salva-vidas, é uma suculenta de crescimento lento com caules carnosos e flores listradas em forma de anel. Prefere luz indireta brilhante e pouca água."
    },
    "ar": {
      "common_name": "نبات عوامة النجاة",
      "description": "Huernia zebrina، المعروفة باسم نبات عوامة النجاة، هي عصارية بطيئة النمو ذات سيقان لحمية وأزهار مخططة تشبه الحلقة. تفضل الضوء الساطع غير المباشر والري القليل."
    },
    "hi": {
      "common_name": "लाइफसेवर पौधा",
      "description": "Huernia zebrina, जिसे लाइफसेवर पौधा कहा जाता है, मांसल तनों और छल्ले जैसे धारीदार फूलों वाला धीमी वृद्धि का रसीला पौधा है। इसे तेज़ अप्रत्यक्ष रोशनी और कम पानी पसंद है।"
    },
    "zh": {
      "common_name": "救生圈植物",
      "description": "Huernia zebrina，又称救生圈植物，是一种生长缓慢的多肉植物，具有肉质茎和环状条纹花。它喜欢明亮的散射光，只需少量浇水。"
    },
    "ja": {
      "common_name": "ライフセーバープラント",
      "description": "Huernia zebrina（ライフセーバープラント）は、肉質の茎と輪のような縞模様の花を持つ、ゆっくり育つ多肉植物です。明るい間接光を好み、水やりは控えめで十分です。"
    },
    "ko": {
      "common_name": "라이프세이버 식물",
      "description": "Huernia zebrina, 또는 라이프세이버 식물은 다육질 줄기와 고리 모양의 줄무늬 꽃을 가진 느리게 자라는 다육식물입니다. 밝은 간접광을 좋아하고 물은 적게 필요합니다."
    }
  },
