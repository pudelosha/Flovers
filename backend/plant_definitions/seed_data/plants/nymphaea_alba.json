  "translations": {
    "en": {
      "common_name": "White Water Lily",
      "description": "Nymphaea alba is a beautiful aquatic plant that grows in calm, shallow waters. It is known for its large, white, fragrant flowers that bloom during the summer."
    },
    "pl": {
      "common_name": "Lilia wodna biała",
      "description": "Nymphaea alba to piękna roślina wodna, która rośnie w spokojnych, płytkich wodach. Jest znana z dużych, białych, pachnących kwiatów, które kwitną latem."
    },
    "de": {
      "common_name": "Weiße Seerose",
      "description": "Nymphaea alba ist eine wunderschöne Wasserpflanze, die in ruhigen, flachen Gewässern wächst. Sie ist bekannt für ihre großen, weißen, duftenden Blüten, die im Sommer blühen."
    },
    "fr": {
      "common_name": "Nymphaea blanche",
      "description": "Nymphaea alba est une belle plante aquatique qui pousse dans des eaux calmes et peu profondes. Elle est connue pour ses grandes fleurs blanches parfumées qui fleurissent en été."
    },
    "it": {
      "common_name": "Ninfea bianca",
      "description": "Nymphaea alba è una bellissima pianta acquatica che cresce in acque calme e poco profonde. È nota per i suoi grandi fiori bianchi profumati che sbocciano in estate."
    },
    "es": {
      "common_name": "Nenúfar blanco",
      "description": "Nymphaea alba es una hermosa planta acuática que crece en aguas tranquilas y poco profundas. Es conocida por sus grandes flores blancas fragantes que florecen durante el verano."
    },
    "pt": {
      "common_name": "Ninféia branca",
      "description": "Nymphaea alba é uma bela planta aquática que cresce em águas calmas e rasas. É conhecida por suas grandes flores brancas perfumadas que florescem durante o verão."
    },
    "ar": {
      "common_name": "زنبق الماء الأبيض",
      "description": "Nymphaea alba هي نبتة مائية جميلة تنمو في المياه الهادئة والضحلة. تشتهر بأزهارها البيضاء الكبيرة والعطرة التي تتفتح في الصيف."
    },
    "hi": {
      "common_name": "सफेद जल कमल",
      "description": "Nymphaea alba एक सुंदर जलप्लावक पौधा है जो शांत, उथले पानी में उगता है। यह अपने बड़े, सफेद, खुशबूदार फूलों के लिए जाना जाता है जो गर्मियों में खिलते हैं।"
    },
    "zh": {
      "common_name": "白睡莲",
      "description": "Nymphaea alba 是一种美丽的水生植物，生长在平静的浅水中。它以其盛开的白色芳香花朵而闻名，通常在夏季开花。"
    },
    "ja": {
      "common_name": "白いスイレン",
      "description": "Nymphaea alba は穏やかな浅い水域で育つ美しい水生植物です。夏に咲く大きな白い香りの良い花で知られています。"
    },
    "ko": {
      "common_name": "흰 수련",
      "description": "Nymphaea alba는 조용하고 얕은 물에서 자라는 아름다운 수생 식물입니다. 여름 동안 피는 크고 흰 향기로운 꽃으로 알려져 있습니다."
    }
  },
