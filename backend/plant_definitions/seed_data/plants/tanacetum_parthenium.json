  "translations": {
    "en": {
      "common_name": "Feverfew",
      "description": "Feverfew is a perennial herb used in traditional medicine. It thrives in moderate light and well-drained soil."
    },
    "pl": {
      "common_name": "Maruna bezwonna",
      "description": "Maruna bezwonna to wieloletnia roślina lecznicza. Rośnie w średnim świetle i dobrze przepuszczalnej glebie."
    },
    "de": {
      "common_name": "Mutterkraut",
      "description": "Mutterkraut ist ein mehrjähriges Kraut, das in der traditionellen Medizin verwendet wird. Es wächst bei mäßigem Licht und in gut durchlässigem Boden."
    },
    "fr": {
      "common_name": "Grande camomille",
      "description": "La grande camomille est une plante vivace utilisée en médecine traditionnelle. Elle pousse avec une lumière modérée et dans un sol bien drainé."
    },
    "it": {
      "common_name": "Partenio",
      "description": "Il partenio è una pianta perenne usata nella medicina tradizionale. Cresce con luce moderata e in terreni ben drenati."
    },
    "es": {
      "common_name": "Matricaria",
      "description": "La matricaria es una planta perenne utilizada en medicina tradicional. Crece con luz moderada y en suelos bien drenados."
    },
    "pt": {
      "common_name": "Matricária",
      "description": "A matricária é uma planta perene usada na medicina tradicional. Cresce com luz moderada e solo bem drenado."
    },
    "ar": {
      "common_name": "حشيشة الحمى",
      "description": "حشيشة الحمى نبات معمر يستخدم في الطب التقليدي. ينمو في ضوء معتدل وتربة جيدة التصريف."
    },
    "hi": {
      "common_name": "फीवरफ्यू",
      "description": "फीवरफ्यू पारंपरिक औषधि में उपयोग होने वाली बारहमासी जड़ी-बूटी है। यह मध्यम रोशनी और अच्छी जल निकासी वाली मिट्टी में उगती है।"
    },
    "zh": {
      "common_name": "小白菊",
      "description": "小白菊是一种多年生草本植物，常用于传统草药。它适合中等光照和排水良好的土壤。"
    },
    "ja": {
      "common_name": "ナツシロギク",
      "description": "ナツシロギクは伝統的に利用されてきた多年草のハーブです。中程度の光と水はけのよい土で育ちます。"
    },
    "ko": {
      "common_name": "피버퓨",
      "description": "피버퓨는 전통 의학에서 사용되어 온 여러해살이 허브입니다. 중간 정도의 빛과 배수가 좋은 흙에서 잘 자랍니다."
    }
  },
