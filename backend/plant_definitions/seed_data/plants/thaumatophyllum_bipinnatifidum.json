  "translations": {
    "en": {
      "common_name": "Lacy Tree Philodendron",
      "description": "Lacy Tree Philodendron is a large tropical foliage plant with glossy, deeply divided leaves. It prefers bright to moderate indirect light, warmth, and steady humidity."
    },
    "pl": {
      "common_name": "Filodendron drzewiasty",
      "description": "Filodendron drzewiasty to duża tropikalna roślina ozdobna o błyszczących, głęboko powcinanych liściach. Lubi jasne do umiarkowanego światło rozproszone, ciepło i stałą wilgotność."
    },
    "de": {
      "common_name": "Baum-Philodendron",
      "description": "Der Baum-Philodendron ist eine große tropische Blattschmuckpflanze mit glänzenden, tief geteilten Blättern. Er bevorzugt helles bis mäßiges indirektes Licht, Wärme und gleichmäßige Luftfeuchtigkeit."
    },
    "fr": {
      "common_name": "Philodendron arborescent",
      "description": "Le philodendron arborescent est une grande plante tropicale au feuillage brillant et profondément découpé. Il préfère une lumière indirecte vive à modérée, la chaleur et une humidité régulière."
    },
    "it": {
      "common_name": "Filodendro ad albero",
      "description": "Il filodendro ad albero è una grande pianta tropicale da foglia con foglie lucide e profondamente divise. Preferisce luce indiretta da intensa a moderata, calore e umidità costante."
    },
    "es": {
      "common_name": "Filodendro arbóreo",
      "description": "El filodendro arbóreo es una gran planta tropical de follaje con hojas brillantes y profundamente divididas. Prefiere luz indirecta brillante a moderada, calor y humedad constante."
    },
    "pt": {
      "common_name": "Filodendro-arbóreo",
      "description": "O filodendro-arbóreo é uma grande planta tropical de folhagem, com folhas brilhantes e profundamente divididas. Prefere luz indireta brilhante a moderada, calor e umidade constante."
    },
    "ar": {
      "common_name": "فيلوديندرون شجري",
      "description": "الفيلوديندرون الشجري نبات ورقي استوائي كبير بأوراق لامعة ومقسمة بعمق. يفضل الضوء غير المباشر الساطع إلى المتوسط والدفء والرطوبة المنتظمة."
    },
    "hi": {
      "common_name": "लेसी ट्री फिलोडेंड्रोन",
      "description": "लेसी ट्री फिलोडेंड्रोन चमकदार, गहरे कटे पत्तों वाला बड़ा उष्णकटिबंधीय पर्णीय पौधा है। इसे तेज़ से मध्यम अप्रत्यक्ष रोशनी, गर्माहट और स्थिर नमी पसंद है।"
    },
    "zh": {
      "common_name": "裂叶蔓绿绒",
      "description": "裂叶蔓绿绒是大型热带观叶植物，叶片有光泽且深裂。它喜欢明亮到中等的散射光、温暖环境和稳定湿度。"
    },
    "ja": {
      "common_name": "ツリーフィロデンドロン",
      "description": "ツリーフィロデンドロンは、光沢のある深く切れ込んだ葉を持つ大型の熱帯観葉植物です。明るい〜中程度の間接光、暖かさ、安定した湿度を好みます。"
    },
    "ko": {
      "common_name": "나무 필로덴드론",
      "description": "나무 필로덴드론은 윤기 있고 깊게 갈라진 잎을 가진 큰 열대 관엽식물입니다. 밝거나 중간 정도의 간접광, 따뜻함, 일정한 습도를 좋아합니다."
    }
  },
